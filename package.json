{
  "name": "request-throttling-manager",
  "version": "1.0.0",
  "description": "Advanced request throttling system with token bucket, dynamic capacity, and graceful shutdown",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:integration": "jest tests/integration",
    "test:load": "artillery run tests/load/throttle-test.yml",
    "verify": "node verify.js",
    "capacity:calculate": "node scripts/capacity-calculator/calculate.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "setup:cron": "bash scripts/setup-cron.sh",
    "policy:deploy": "bash scripts/policy-deployer/deploy.sh deploy",
    "policy:rollback": "bash scripts/policy-deployer/deploy.sh rollback",
    "lint": "eslint src/ --fix"
  },
  "keywords": [
    "rate-limiting",
    "throttling",
    "token-bucket",
    "api-gateway",
    "capacity-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "ioredis-mock": "^8.13.1",
    "mongoose": "^7.5.0",
    "node-cron": "^3.0.2",
    "redis-server": "^1.2.2"
  },
  "devDependencies": {
    "artillery": "^2.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.6.4",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
